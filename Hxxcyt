local function applyCarPhysics()
    if not settings.enabled then return end
    if not currentCar then return end
    
    local primaryPart = currentCar.PrimaryPart or currentCar:FindFirstChildWhichIsA("BasePart")
    if not primaryPart then return end
    
    local currentPosition = primaryPart.Position
    
    if lastPosition then
        -- Calculate velocity
        velocity = (currentPosition - lastPosition) * 60 -- Approximate velocity
        
        -- Calculate tilt based on velocity change
        local lateralVelocity = Vector3.new(velocity.X, 0, velocity.Z)
        local speed = lateralVelocity.Magnitude
        
        if speed > 5 then -- Only apply physics when moving
            -- Tilt effect
            local tiltX = math.clamp(-velocity.Z * settings.tiltIntensity, -settings.maxTilt, settings.maxTilt)
            local tiltZ = math.clamp(velocity.X * settings.tiltIntensity, -settings.maxTilt, settings.maxTilt)
            
            -- Bounce effect (vertical)
            local bounceY = math.sin(tick() * 10) * settings.bounceIntensity * (speed / 10)
            
            -- Apply rotation
            for _, part in pairs(currentCar:GetDescendants()) do
                if part:IsA("BasePart") and not part:IsA("VehicleSeat") then
                    local currentCF = part.CFrame
                    local offset = CFrame.Angles(
                        math.rad(tiltX),
                        0,
                        math.rad(tiltZ)
                    ) * CFrame.new(0, bounceY, 0)
                    
                    part.CFrame = currentCF:Lerp(currentCF * offset, settings.returnSpeed)
                end
            end
        else
            -- Return to normal slowly
            for _, part in pairs(currentCar:GetDescendants()) do
                if part:IsA("BasePart") and not part:IsA("VehicleSeat") then
                    local currentCF = part.CFrame
                    local targetCF = CFrame.new(currentCF.Position) * CFrame.Angles(0, currentCF:ToEulerAnglesXYZ())
                    part.CFrame = currentCF:Lerp(targetCF, settings.returnSpeed * 0.5)
                end
            end
        end
    end
    
    lastPosition = currentPosition
end

local function startPhysics()
    if connection then
        connection:Disconnect()
    end
    
    connection = RunService.Heartbeat:Connect(function()
        currentCar = findCar()
        if currentCar and settings.enabled then
            applyCarPhysics()
        else
            lastPosition = nil
        end
    end)
end

